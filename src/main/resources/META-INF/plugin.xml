<idea-plugin>
    <id>com.omnetpp.omnetpp_plugin</id>
    <name>Omnetpp_plugin</name>
    <vendor url="https://www.yourcompany2.com">Hello</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- ── NED ──────────────────────────────────────────────────────── -->
        <fileType
                name="NED"
                implementationClass="com.omnetpp.omnetpp_plugin.ned.NedFileType"
                extensions="ned"/>

        <lang.parserDefinition
                language="NED"
                implementationClass="com.omnetpp.omnetpp_plugin.ned.NedParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="NED"
                implementationClass="com.omnetpp.omnetpp_plugin.ned.highlighting.NedSyntaxHighlighterFactory"/>

        <colorSettingsPage implementation="com.omnetpp.omnetpp_plugin.ned.highlighting.NedColorSettingsPage"/>

        <psi.referenceContributor
                language="NED"
                implementation="com.omnetpp.omnetpp_plugin.ned.references.NedReferenceContributor"/>

        <!-- ── INI ──────────────────────────────────────────────────────── -->
        <fileType name="OMNeT++ INI"
                  language="OMNET_INI"
                  implementationClass="com.omnetpp.omnetpp_plugin.ini.IniFileType"
                  extensions="ini"/>

        <lang.parserDefinition language="OMNET_INI"
                               implementationClass="com.omnetpp.omnetpp_plugin.ini.IniParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="OMNET_INI"
                implementationClass="com.omnetpp.omnetpp_plugin.ini.highlighting.IniSyntaxHighlighterFactory"/>

        <colorSettingsPage implementation="com.omnetpp.omnetpp_plugin.ini.highlighting.IniColorSettingsPage"/>

        <!--
            NEW: resolves  network = SomeNetwork  in .ini files
                 to the matching  network SomeNetwork { }  in .ned files.
        -->
        <gotoDeclarationHandler
                implementation="com.omnetpp.omnetpp_plugin.ini.references.IniNetworkGoToDeclarationHandler"/>

        <codeInsight.lineMarkerProvider
                language="OMNET_INI"
                implementationClass="com.omnetpp.omnetpp_plugin.ini.runner.IniConfigLineMarkerProvider"/>

        <applicationConfigurable
                id="omnetpp.run.settings"
                displayName="OMNeT++ Run"
                instance="com.omnetpp.omnetpp_plugin.ini.runner.config.OmnetRunSettingsConfigurable"/>

        <configurationType implementation="com.omnetpp.omnetpp_plugin.ini.runner.rc.OmnetIniRunConfigurationType"/>

        <runConfigurationProducer implementation="com.omnetpp.omnetpp_plugin.ini.runner.rc.OmnetIniRunConfigurationProducer"/>

    </extensions>
</idea-plugin>